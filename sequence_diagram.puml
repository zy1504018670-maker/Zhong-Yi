title Use Case 3 - Daily limit rule is triggered

participant "GameMonitor" as Monitor3
participant "TaskManager" as Tasks3
participant "DataLogger" as Logger3
participant "SettingsStore" as Settings

Monitor3 -> Settings: load()
Settings --> Monitor3: daily_limit_minutes
Monitor3 -> Logger3: get_total_today()
Logger3 --> Monitor3: total logged minutes
Monitor3 -> Tasks3: get_pending_tasks()
Tasks3 --> Monitor3: pending tasks
Monitor3 -> Monitor3: calculate current session minutes

alt daily limit exceeded
  Monitor3 -> Monitor3: add rule flag daily_limit_exceeded
  Monitor3 -> Monitor3: print warning
  alt auto shutdown enabled
    Monitor3 -> Monitor3: schedule OS shutdown timer
  end
else limits are normal
  Monitor3 -> Monitor3: continue monitoring
end
@enduml
